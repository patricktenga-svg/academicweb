<body class="d-flex flex-column min-vh-100 {% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
  
  {% include header.liquid %}

  <div class="container mt-5 flex-grow-1" role="main">
    {% if page.toc and page.toc.sidebar %}
      {% if page.toc.sidebar == 'right' %}
        <div class="row">
          <div class="col-sm-9">{{ content }}</div>
          <div class="col-sm-3">
            <nav id="toc-sidebar" class="sticky-top"></nav>
          </div>
        </div>
      {% else %}
        <div class="row">
          <div class="col-sm-3">
            <nav id="toc-sidebar" class="sticky-top"></nav>
          </div>
          <div class="col-sm-9">{{ content }}</div>
        </div>
      {% endif %}
    {% else %}
      {{ content }}
    {% endif %}
  </div>

  {% include footer.liquid %}

  {% include scripts.liquid %}
</body>